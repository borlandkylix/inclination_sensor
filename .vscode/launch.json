    "configurations": [
        {
            "name": "Debug STM32F767ZI Remote",
            "cwd": "${workspaceFolder}",
            "armToolchainPath": "${env:ZEPHYR_SDK}/arm-zephyr-eabi/bin/",
            "toolchainPrefix": "arm-zephyr-eabi",
            "executable": "${workspaceRoot}/build/zephyr/zephyr.elf",
            "request": "launch",
            "type": "cortex-debug",
            "device": "STM32F767ZI",
            "servertype": "external",
            "showDevDebugOutput": "both",
            "gdbTarget": "localhost:2331",
            // "serverpath": "/usr/local/bin/west",
            // "serverArgs": ["debugserver -r jlink"],
            "overrideLaunchCommands": [
              "monitor reset",
              "-target-download",
              "monitor reset"
            ],
            "overrideRestartCommands": ["monitor reset"],
            "runToEntryPoint": "main"
        },
        {
            "name": "Debug ESP32 Remote",
            "cwd": "${workspaceFolder}",
            "armToolchainPath": "${env:ZEPHYR_SDK}/xtensa-espressif_esp32_zephyr-elf/bin/",
            "toolchainPrefix": "xtensa-espressif_esp32_zephyr-elf",
            "executable": "${workspaceRoot}/build/zephyr/zephyr.elf",
            "request": "launch",
            "type": "cortex-debug",
            //"device": "STM32F767ZI",
            "servertype": "external",
            "showDevDebugOutput": "both",
            "gdbTarget": "localhost:3333",
            "overrideLaunchCommands": [
                "set remote hardware-watchpoint-limit 2",
                "flushregs",
                "mon reset halt"
            ],
            "overrideRestartCommands": [
                "mon reset halt",
                "flushregs",
            ],
            "runToEntryPoint": "main"
        },
        {
            "name": "Debug ESP32 Remote GDB",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceRoot}/build/zephyr/zephyr.elf",
            "cwd": "${workspaceFolder}",
            "stopAtEntry": true,
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "${env:ZEPHYR_SDK}/xtensa-espressif_esp32_zephyr-elf/bin/xtensa-espressif_esp32_zephyr-elf-gdb",
            "miDebuggerServerAddress":"localhost:3333",
            "postRemoteConnectCommands": [
                "monitor reset halt"
            ],
        },
