    	{
            //this configuration works better, no need to start openocd manually.
            "name": "ESP32C6 (Better)",
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceRoot}/build/zephyr/zephyr.elf",
            "request": "attach",
            "type": "cortex-debug",
            "servertype": "openocd",
            "interface": "jtag",
            //"svdFile": "${config:bsp.svd_path}/esp32c6.svd",
            "serverpath": "${env:ESPRESSIF_TOOLCHAIN_PATH}/openocd-esp32/bin/openocd",
            "toolchainPath": "${env:ZEPHYR_SDK}/riscv64-zephyr-elf/bin/",
            "toolchainPrefix": "riscv64-zephyr-elf",
            "openOCDPreConfigLaunchCommands":[
                "set ESP_RTOS Zephyr",
            ],
            "openOCDLaunchCommands": [
                "init",
                "reset halt",
                "esp appimage_offset 0x0"
            ],
            "configFiles": [
                "board/esp32c6-builtin.cfg",
            ],
            "overrideAttachCommands": [
                "mon reset halt",
                "maintenance flush register-cache"
            ],
            "overrideRestartCommands": [
                "mon reset halt",
                "maintenance flush register-cache",
            ],
            "runToEntryPoint": "main",
        },
